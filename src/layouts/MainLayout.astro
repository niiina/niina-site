---
// src/layouts/MainLayout.astro
const { title } = Astro.props;
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;600&display=swap" rel="stylesheet">
		<title>{title} | Niina Pollari</title>
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
	</head>
	<body>
		<main>
			<header class="site-header">
				<h1>NIINA POLLARI</h1>
			</header>

			<nav class="top-nav">
				<ul>
					<li><a href="/">Home</a></li>
					<li><a href="/about">About</a></li>
					<li><a href="/books">Books</a></li>
					<li><a href="/other-writing">Other Writing</a></li>
					<li><a href="https://sadreview.substack.com">Newsletter</a></li>
				</ul>
			</nav>

			<slot /> 
		</main>

		<style is:global>
            /* HOMEPAGE SPECIFIC STYLES */
    .book-grid {
        display: grid;
        grid-template-columns: 320px 1fr; 
        gap: 5rem;
        align-items: center;
        margin-bottom: 8rem;
        margin-top: 2rem;
    }

    .book-visual img {
        width: 100%;
        height: auto;
        box-shadow: 0 20px 50px rgba(0,0,0,0.12); 
    }

    .book-title { 
        font-size: 2.8rem; 
        margin: 0 0 0.5rem; 
        font-weight: normal; 
    }
    
    .publisher { 
        font-style: italic; 
        color: #999; 
        margin-bottom: 2.5rem; 
        font-size: 1.1rem;
    }

    .praise {
        font-size: 1.3rem;
        line-height: 1.8;
        margin: 2.5rem 0;
        padding-left: 2rem;
        border-left: 1px solid #ccc;
    }
    
    cite { 
        display: block; 
        font-size: 0.95rem; 
        margin-top: 1.2rem; 
        color: #777; 
        font-family: 'Inter', sans-serif;
        font-style: normal;
        text-transform: uppercase;
    }

    /* BUTTONS */
    .buy-links { display: flex; gap: 1.5rem; }
    
    .btn {
        display: inline-block;
        padding: 1rem 1.8rem;
        text-decoration: none;
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }
    
    .primary { background: #1a1a1a; color: #fff; }
    .secondary { border: 1px solid #1a1a1a; color: #1a1a1a; }
			/* Global styles that apply to every page */
			* { box-sizing: border-box; }
			body { 
				margin: 0; 
				padding: 0; 
				background-color: #fdfdfd; 
				color: #1a1a1a;
				font-family: 'Libre Baskerville', serif;
			}
			main { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
			.site-header { text-align: center; padding: 5rem 0 2.5rem; }
			.site-header h1 { font-size: 3.2rem; letter-spacing: 0.3rem; font-weight: normal; margin: 0; }
			.top-nav { border-top: 1px solid #eee; border-bottom: 1px solid #eee; margin-bottom: 5rem; padding: 1.2rem 0; }
			.top-nav ul { list-style: none; display: flex; justify-content: center; gap: 3rem; padding: 0; margin: 0; }
			.top-nav a { text-decoration: none; color: #223c2e; font-family: 'Inter', sans-serif; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1.5px; }
			.top-nav a:hover { color: #000; }
			
			/* Page-specific layout styles */
			.content-page h2 { font-weight: normal; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 3rem; }
			.about-grid { display: grid; grid-template-columns: 350px 1fr; gap: 4rem; align-items: start; }
			.profile-photo img { width: 100%; height: auto; box-shadow: 0 15px 35px rgba(0,0,0,0.08); }
			.bio-text { line-height: 1.8; font-size: 1.1rem; }

			@media (max-width: 850px) {
				.about-grid { grid-template-columns: 1fr; text-align: center; }
				.profile-photo img { max-width: 280px; margin: 0 auto 2rem; }
			}
		</style>
	</body>
</html>
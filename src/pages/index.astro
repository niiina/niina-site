---
// index.astro
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;600&display=swap" rel="stylesheet">
		<title>Niina Pollari</title>
	</head>
	<body>
		<main>
			<header class="site-header">
				<h1>NIINA POLLARI</h1>
			</header>

			<nav class="top-nav">
				<ul>
					<li><a href="/">Home</a></li>
					<li><a href="/about">About</a></li>
					<li><a href="/books">Books</a></li>
					<li><a href="/other-writing">Other Writing</a></li>
					<li><a href="https://yoursubstack.substack.com">Newsletter</a></li>
					<li><a href="/contact">Contact</a></li>
				</ul>
			</nav>

			<section class="hero">
				<div class="book-grid">
					<div class="book-visual">
						<img src="/pathcover.gif" alt="Path of Totality" />
					</div>

					<div class="book-info">
						<h2 class="book-title">Path of Totality</h2>
						<p class="publisher">Soft Skull Press, 2022</p>
						
						<blockquote class="praise">
							"Mysteriously empowering, as though it offered proof that the human mind is equal to great tragedy."
							<cite>— Elisa Gabbert, New York Times</cite>
						</blockquote>

						<div class="buy-links">
							<a href="https://softskull.com/dd-product/path-of-totality/" class="btn primary">Buy from Publisher</a>
							<a href="https://bookshop.org" class="btn secondary">Bookshop</a>
						</div>
					</div>
				</div>
			</section>
		</main>

		<style>
    /* 1. THE RESET - This fixes the "ugly" look */
    * { box-sizing: border-box; }
    
    body { 
        margin: 0; 
        padding: 0; 
        background-color: #fdfdfd; 
        color: #1a1a1a;
        font-family: 'Libre Baskerville', serif;
        -webkit-font-smoothing: antialiased;
    }

    main { 
        max-width: 1100px; 
        margin: 0 auto; 
        padding: 0 2rem; 
    }

    /* 2. HEADER & NAVIGATION */
    .site-header { 
        text-align: center; 
        padding: 5rem 0 2.5rem; 
    }
    
    .site-header h1 { 
        font-size: 3.2rem; 
        letter-spacing: 0.3rem; 
        font-weight: normal; 
        margin: 0;
    }

    .top-nav { 
        border-top: 1px solid #eee;
        border-bottom: 1px solid #eee;
        margin-bottom: 5rem;
        padding: 1.2rem 0;
    }
    
    .top-nav ul { 
        list-style: none; 
        display: flex; 
        justify-content: center; 
        gap: 3rem; 
        padding: 0;
        margin: 0;
    }
    
    .top-nav a { 
        text-decoration: none; 
        color: #777; 
        font-family: 'Inter', sans-serif;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }
    
    .top-nav a:hover { color: #000; }

    /* 3. THE BOOK GRID */
    .book-grid {
        display: grid;
        grid-template-columns: 320px 1fr; 
        gap: 5rem;
        align-items: center;
        margin-bottom: 8rem;
    }

    .book-visual img {
        width: 100%;
        height: auto;
        box-shadow: 0 20px 50px rgba(0,0,0,0.12); 
    }

    .book-title { 
        font-size: 2.8rem; 
        margin: 0 0 0.5rem; 
        font-weight: normal; 
    }
    
    .publisher { 
        font-style: italic; 
        color: #999; 
        margin-bottom: 2.5rem; 
        font-size: 1.1rem;
    }

    .praise {
        font-size: 1.3rem;
        line-height: 1.8;
        margin: 2.5rem 0;
        padding-left: 2rem;
        border-left: 1px solid #ccc;
    }
    
    cite { 
        display: block; 
        font-size: 0.95rem; 
        margin-top: 1.2rem; 
        color: #777; 
        font-family: 'Inter', sans-serif;
        font-style: normal;
        text-transform: uppercase;
    }

    /* 4. BUTTONS */
    .buy-links { display: flex; gap: 1.5rem; }
    
    .btn {
        display: inline-block;
        padding: 1rem 1.8rem;
        text-decoration: none;
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }
    
    .primary { background: #1a1a1a; color: #fff; }
    .secondary { border: 1px solid #1a1a1a; color: #1a1a1a; }

    /* 5. MOBILE VIEW */
    @media (max-width: 850px) {
        .book-grid { grid-template-columns: 1fr; text-align: center; }
        .book-visual img { max-width: 280px; margin: 0 auto; }
        .top-nav ul { flex-direction: column; align-items: center; gap: 1.5rem; }
    }
</style>
	</body>
</html>
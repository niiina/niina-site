---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Books">
    <section class="content-page">
        <h2>Books</h2>

        <div class="books-archive">
            <div class="book-row">
                <div class="book-thumbnail">
                    <img src="/deadhorse.gif" alt="Dead Horse" />
                </div>
                <div class="book-info">
                    <h3>Dead Horse</h3>
                    <p class="book-meta">Birds, LLC 2015</p>
                    <p class="description">
                        Debut full-length collection published in 2015. There are three sections, Blood, Bones, and Money. These are informal poems exploring what it means to have a body on earth.
                    </p>
                    <p class="small-praise">
                        "You will see your own skull." — <em>Melissa Broder</em>
                    </p>
                    <a href="https://www.birdsllc.com/catalog/dead-horse" class="publisher-link">Birds, LLC &rarr;</a>
                </div>
            </div>

            </div>
            <div class="books-archive">
            <div class="book-row">
                <div class="book-thumbnail">
                    <img src="/deadhorse.gif" alt="Dead Horse" />
                </div>
                <div class="book-info">
                    <h3>The Warmth of the Taxidermied Animal</h3>
                    <p class="book-meta">Birds, LLC 2015</p>
                    <p class="description">
                        Debut translation, in full bilingual edition, of the transcendent selected works of Finnish poet Tytti Heikkinen. Published by Action Books in 2012. 
                    </p>
                    <p class="small-praise">
                        "Heikkinen dials the right-wrong number of her spirit phone, a cozy failure, bleeding out on Christmas Eve." — <em>Danielle Pafunda</em>
                    </p>
                    <a href="https://actionbooks.org/tytti-heikkinen-taxidermied/" class="publisher-link">Action Books &rarr;</a>
                </div>
            </div>

            </div>
    </section>
</MainLayout>

<style>
    .books-archive {
        display: flex;
        flex-direction: column;
        gap: 6rem;
        margin-top: 3rem;
    }

    .book-row {
        display: grid;
        grid-template-columns: 180px 1fr; /* Smaller cover size (180px) */
        gap: 3rem;
        align-items: start;
    }

    .book-thumbnail img {
        width: 100%;
        height: auto;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .book-info h3 {
        font-size: 1.8rem;
        margin: 0 0 0.5rem 0;
        font-weight: normal;
    }

    .book-meta {
        font-style: italic;
        color: #888;
        margin-bottom: 1.5rem;
    }

    .description {
        line-height: 1.6;
        margin-bottom: 1rem;
    }

    .small-praise {
        font-size: 0.95rem;
        color: #555;
        border-left: 2px solid #eee;
        padding-left: 1rem;
        margin-bottom: 1.5rem;
    }

    .publisher-link {
        color: #1a1a1a;
        text-decoration: none;
        font-family: 'Inter', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .publisher-link:hover {
        text-decoration: underline;
    }

    /* Mobile view */
    @media (max-width: 700px) {
        .book-row {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .book-thumbnail img {
            max-width: 150px;
            margin: 0 auto;
        }
        .small-praise {
            border-left: none;
            border-top: 1px solid #eee;
            padding: 1rem 0 0 0;
        }
    }
</style>